{
  "id": null,
  "uid": "openclaw-gateway",
  "title": "OpenClaw Gateway",
  "tags": ["openclaw","gateway","ws"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Backend UP",
      "targets": [
        {
          "expr": "up{job=\"openclaw\"}",
          "legendFormat": "status"
        }
      ],
      "gridPos": {"h":3,"w":4,"x":0,"y":0}
    },
    {
      "type": "graph",
      "title": "Websocket Connections",
      "targets": [
        {
          "expr": "rate(openclaw_ws_connections_total[5m])",
          "legendFormat": "WS Conn/sec"
        }
      ],
      "gridPos": {"h":8,"w":12,"x":0,"y":3}
    },
    {
      "type": "graph",
      "title": "Error Rate",
      "targets": [
        {
          "expr": "rate(openclaw_errors_total[5m])",
          "legendFormat": "errors"
        }
      ],
      "gridPos": {"h":8,"w":12,"x":12,"y":3}
    },
    {
      "type": "graph",
      "title": "Latency (ms)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(openclaw_latency_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": {"h":8,"w":24,"x":0,"y":11}
    }
  ]
}