{
  "id": null,
  "uid": "openclaw-gateway-pro",
  "title": "OpenClaw Gateway PRO",
  "tags": ["openclaw", "gateway", "websocket", "token", "pairing"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "style": "dark",
  "panels": [

    {
      "type": "stat",
      "title": "Gateway UP",
      "gridPos": { "x": 0, "y": 0, "w": 3, "h": 3 },
      "targets": [
        {
          "expr": "up{job=\"openclaw\"}",
          "legendFormat": "gateway"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false },
        "orientation": "auto"
      }
    },

    {
      "type": "stat",
      "title": "WS Active Connections",
      "gridPos": { "x": 3, "y": 0, "w": 3, "h": 3 },
      "targets": [
        {
          "expr": "sum(openclaw_ws_connections_active)",
          "legendFormat": "active"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false }
      }
    },

    {
      "type": "stat",
      "title": "WS Error Rate (5m)",
      "gridPos": { "x": 6, "y": 0, "w": 3, "h": 3 },
      "targets": [
        {
          "expr": "rate(openclaw_ws_errors_total[5m])",
          "legendFormat": "errors/s"
        }
      ]
    },

    {
      "type": "stat",
      "title": "Token Rejected",
      "gridPos": { "x": 9, "y": 0, "w": 3, "h": 3 },
      "targets": [
        {
          "expr": "increase(openclaw_auth_token_rejected_total[10m])",
          "legendFormat": "reject"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "WS Connections (rate)",
      "gridPos": { "x": 0, "y": 3, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(openclaw_ws_connections_total[5m])",
          "legendFormat": "connections/s"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "WS Latency (p50 / p90 / p99)",
      "gridPos": { "x": 12, "y": 3, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(openclaw_ws_latency_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(openclaw_ws_latency_bucket[5m])) by (le))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(openclaw_ws_latency_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Pairing Attempts / Failures",
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "increase(openclaw_pairing_attempt_total[10m])",
          "legendFormat": "attempt"
        },
        {
          "expr": "increase(openclaw_pairing_failed_total[10m])",
          "legendFormat": "failed"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Token Errors (missing / invalid)",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "increase(openclaw_auth_token_missing_total[10m])",
          "legendFormat": "missing"
        },
        {
          "expr": "increase(openclaw_auth_token_invalid_total[10m])",
          "legendFormat": "invalid"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Gateway Error Taxonomy",
      "gridPos": { "x": 0, "y": 19, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "increase(openclaw_errors_auth_total[10m])",
          "legendFormat": "AUTH"
        },
        {
          "expr": "increase(openclaw_errors_pairing_total[10m])",
          "legendFormat": "PAIRING"
        },
        {
          "expr": "increase(openclaw_errors_ws_total[10m])",
          "legendFormat": "WS"
        },
        {
          "expr": "increase(openclaw_errors_proxy_total[10m])",
          "legendFormat": "PROXY"
        },
        {
          "expr": "increase(openclaw_errors_model_total[10m])",
          "legendFormat": "MODEL"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "CPU / Memory (cAdvisor)",
      "gridPos": { "x": 0, "y": 27, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\".*openclaw.*\"}[2m])",
          "legendFormat": "cpu"
        },
        {
          "expr": "container_memory_usage_bytes{name=~\".*openclaw.*\"}",
          "legendFormat": "memory"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Per-Route Latency (HTTP/WS)",
      "gridPos": { "x": 12, "y": 27, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(openclaw_route_latency_seconds_sum[5m]) / rate(openclaw_route_latency_seconds_count[5m])",
          "legendFormat": "{{route}}"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" }
}
