{
  "id": null,
  "uid": "openclaw-ws-insights",
  "title": "OpenClaw WebSocket Insights",
  "tags": ["openclaw", "websocket", "ws", "latency", "session"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "style": "dark",
  "timezone": "browser",

  "panels": [

    {
      "type": "stat",
      "title": "Active WS Connections",
      "gridPos": {"x":0,"y":0,"w":4,"h":3},
      "targets": [
        {
          "expr": "sum(openclaw_ws_connections_active)",
          "legendFormat": "Active"
        }
      ],
      "options": {"reduceOptions":{"calcs":["last"]}}
    },

    {
      "type": "stat",
      "title": "Reconnects (5m)",
      "gridPos": {"x":4,"y":0,"w":4,"h":3},
      "targets": [
        {
          "expr": "increase(openclaw_ws_reconnect_total[5m])",
          "legendFormat": "Reconnects"
        }
      ]
    },

    {
      "type": "stat",
      "title": "Disconnects (5m)",
      "gridPos": {"x":8,"y":0,"w":4,"h":3},
      "targets": [
        {
          "expr": "increase(openclaw_ws_disconnect_total[5m])",
          "legendFormat": "Disconnects"
        }
      ]
    },

    {
      "type": "stat",
      "title": "Error Rate (5m)",
      "gridPos": {"x":12,"y":0,"w":4,"h":3},
      "targets": [
        {
          "expr": "rate(openclaw_ws_errors_total[5m])",
          "legendFormat": "errors/s"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "WS Connection Rate",
      "gridPos": {"x":0,"y":3,"w":12,"h":7},
      "targets": [
        {
          "expr": "rate(openclaw_ws_connections_total[5m])",
          "legendFormat": "connections/s"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "WS Ping/Pong Latency",
      "gridPos": {"x":12,"y":3,"w":12,"h":7},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(openclaw_ws_ping_latency_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(openclaw_ws_ping_latency_bucket[5m])) by (le))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(openclaw_ws_ping_latency_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Gateway → Client RTT",
      "gridPos": {"x":0,"y":10,"w":12,"h":7},
      "targets": [
        {
          "expr": "increase(openclaw_ws_rtt_sum[5m]) / increase(openclaw_ws_rtt_count[5m])",
          "legendFormat": "RTT (ms)"
        }
      ]
    },

    {
      "type": "table",
      "title": "Disconnect Reasons (5m)",
      "gridPos": {"x":12,"y":10,"w":12,"h":8},
      "targets": [
        {
          "expr": "increase(openclaw_ws_disconnect_reason_total[5m])",
          "legendFormat": "{{reason}}"
        }
      ]
    },

    {
      "type": "heatmap",
      "title": "Disconnect Cause Heatmap",
      "gridPos": {"x":0,"y":17,"w":12,"h":8},
      "targets": [
        {
          "expr": "rate(openclaw_ws_disconnect_reason_total[5m])",
          "legendFormat": "{{reason}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Browser Types / User Agents",
      "gridPos": {"x":12,"y":17,"w":12,"h":8},
      "targets": [
        {
          "expr": "increase(openclaw_ws_useragent_count_total[10m])",
          "legendFormat": "{{ua}}"
        }
      ]
    }
  ],

  "time": {"from": "now-6h", "to": "now"},
  "templating": {"list":[]}
}
