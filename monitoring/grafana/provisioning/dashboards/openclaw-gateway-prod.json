{
  "title": "OpenClaw – Gateway (Production)",
  "uid": "openclaw-gateway-prod",
  "schemaVersion": 39,
  "version": 6,
  "tags": ["openclaw", "gateway", "teams", "production"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [

    {
      "id": 1,
      "title": "Gateway lifecycle (text logs)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=\"openclaw-gateway\"} |= \"[gateway]\""
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 7 }
    },

    {
      "id": 2,
      "title": "Gateway lifecycle (structured JSON)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=\"openclaw-gateway\"} | json |= \"\\\"subsystem\\\":\\\"gateway\\\"\""
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 7 }
    },

    {
      "id": 3,
      "title": "Microsoft Teams channel activity",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=\"openclaw-gateway\"} | json |= \"\\\"name\\\":\\\"msteams\\\"\""
        }
      ],
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 7 }
    },

    {
      "id": 4,
      "title": "Teams message volume (last 5 min)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "count_over_time(({container=\"openclaw-gateway\"} | json |= \"\\\"name\\\":\\\"msteams\\\"\")[5m])"
        }
      ],
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 7 }
    },

    {
      "id": 5,
      "title": "Warnings & Errors (all components)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=~\"openclaw-(gateway|agent|blackbox)\"} |~ \"WARN|ERROR|error:\""
        }
      ],
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 7 }
    },

    {
      "id": 6,
      "title": "Internal subsystems (plugins / cron / bonjour)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=\"openclaw-gateway\"} | json |~ \"subsystem\\\":\\\"(plugins|cron|bonjour|heartbeat|health-monitor)\"\""
        }
      ],
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 7 }
    },

    {
      "id": 7,
      "title": "Raw OpenClaw logs (debug / ground truth)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=~\"openclaw-.*\"}"
        }
      ],
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 10 }
    }
  ]
}
