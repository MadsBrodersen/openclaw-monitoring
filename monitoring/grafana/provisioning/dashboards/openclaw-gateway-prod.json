{
  "title": "OpenClaw – Gateway (Production)",
  "uid": "openclaw-gateway-prod",
  "schemaVersion": 39,
  "version": 7,
  "tags": ["openclaw", "gateway", "teams", "production"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [

    {
      "id": 1,
      "type": "logs",
      "title": "Microsoft Teams – Activity",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=\"openclaw-gateway\", channel=\"msteams\"}"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },

    {
      "id": 2,
      "type": "timeseries",
      "title": "Microsoft Teams – Message volume",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "count_over_time({container=\"openclaw-gateway\", channel=\"msteams\"}[$__interval])"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },

    {
      "id": 3,
      "type": "logs",
      "title": "Gateway lifecycle",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=\"openclaw-gateway\", subsystem=\"gateway\"}"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },

    {
      "id": 4,
      "type": "logs",
      "title": "Warnings & Errors",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=~\"openclaw-(gateway|agent|blackbox)\"} |~ \"WARN|ERROR\""
        }
      ],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    },

    {
      "id": 5,
      "type": "logs",
      "title": "Internal subsystems (cron / plugins / health)",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=\"openclaw-gateway\", subsystem=~\"plugins|health-monitor\"}"
        },
        {
          "expr": "{container=\"openclaw-gateway\", module=\"cron\"}"
        }
      ],
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 }
    },

    {
      "id": 6,
      "type": "logs",
      "title": "Raw OpenClaw logs (ground truth)",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=~\"openclaw-.*\"}"
        }
      ],
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 10 }
    }
  ]
}
