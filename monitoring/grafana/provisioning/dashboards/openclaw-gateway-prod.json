{
  "title": "OpenClaw – Gateway (Production)",
  "uid": "openclaw-gateway-prod",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "tags": ["openclaw", "gateway", "production", "logs"],
  "panels": [
    {
      "id": 1,
      "title": "Gateway log volume (per minute)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "count_over_time({container=~\".*openclaw.*\"}[1m])"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 2,
      "title": "Gateway errors",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=~\".*openclaw.*\"} |~ \"(error|exception|panic)\""
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 3,
      "title": "NGINX → OpenClaw request volume",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "count_over_time({container=\"nginx\"} |= \"/v1/responses\"[1m])"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "id": 4,
      "title": "NGINX → OpenClaw 5xx errors",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=\"nginx\"} |= \"/v1/responses\" |~ \" 5[0-9]{2} \""
        }
      ],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    },
    {
      "id": 5,
      "title": "NGINX access logs (OpenClaw traffic)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=\"nginx\"} |= \"/v1/responses\""
        }
      ],
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 10 }
    },
    {
      "id": 6,
      "title": "OpenClaw raw logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=~\".*openclaw.*\"}"
        }
      ],
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 10 }
    },    
    {
      "id": 7,
      "title": "Teams → OpenClaw message volume",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "count_over_time({container=~\".*openclaw.*\"} |= \"api/messages\"[5m])"
        }
      ],
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 8 }
    },
    {
      "id": 8,
      "title": "Teams → OpenClaw raw logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=~\".*openclaw.*\"} |= \"api/messages\""
        }
      ],
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 8 }
    }
  ]
}
