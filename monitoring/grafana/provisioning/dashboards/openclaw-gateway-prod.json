{
  "title": "OpenClaw – Gateway (Production)",
  "uid": "openclaw-gateway-prod",
  "schemaVersion": 39,
  "version": 2,
  "tags": ["openclaw", "gateway", "production", "logs"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Gateway lifecycle (startup / health)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=~\".*openclaw.*\"} |~ \"\\\"subsystem\\\":\\\"gateway\\\"\"",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 2,
      "title": "Gateway warnings & errors",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=~\".*openclaw.*\"} |~ \"\\\"logLevelName\\\":\\\"(WARN|ERROR)\\\"\"",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 3,
      "title": "Microsoft Teams channel activity",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=~\".*openclaw.*\"} |~ \"\\\"subsystem\\\":\\\"msteams\\\"\"",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "id": 4,
      "title": "Teams message volume (last 5 min)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "count_over_time({container=~\".*openclaw.*\"} |~ \"\\\"subsystem\\\":\\\"msteams\\\"\"[5m])",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    },
    {
      "id": 5,
      "title": "HTTP API usage (/v1/responses via NGINX)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "count_over_time({container=\"nginx\"} |= \"/v1/responses\"[1m])",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 }
    },
    {
      "id": 6,
      "title": "NGINX 4xx & 5xx for OpenClaw API",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=\"nginx\"} |= \"/v1/responses\" |~ \" 4[0-9]{2} | 5[0-9]{2} \"",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 }
    },
    {
      "id": 7,
      "title": "Raw OpenClaw runtime logs (debug / drill-down)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{container=~\".*openclaw.*\"}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 10 }
    }
  ]
}
