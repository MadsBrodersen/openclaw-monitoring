{
  "id": null,
  "uid": "nginx-proxy",
  "title": "Nginx Reverse Proxy",
  "schemaVersion": 36,
  "version": 1,
  "panels": [
    {
      "type": "graph",
      "title": "Requests / Second",
      "targets": [
        {
          "expr": "rate(nginx_http_requests_total[5m])",
          "legendFormat": "req/s"
        }
      ],
      "gridPos": {"h":8,"w":12,"x":0,"y":0}
    },
    {
      "type": "graph",
      "title": "5xx Errors",
      "targets": [
        {
          "expr": "rate(nginx_http_responses_total{status=~\"5..\"}[5m])",
          "legendFormat": "5xx"
        }
      ],
      "gridPos": {"h":8,"w":12,"x":12,"y":0}
    },
    {
      "type": "graph",
      "title": "Upstream Latency",
      "targets": [
        {
          "expr": "rate(nginx_upstream_response_time_seconds_sum[5m]) / rate(nginx_upstream_response_time_seconds_count[5m])",
          "legendFormat": "latency"
        }
      ],
      "gridPos": {"h":8,"w":24,"x":0,"y":8}
    }
  ]
}